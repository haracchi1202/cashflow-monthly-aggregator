# Zoho Analytics API 認証情報（.env として保存）
# このファイルは .env.example。実際の値は .env を別途作って入れる。
# .env は .gitignore で除外済みなのでコミットされない。

# データセンター（リージョン）
# - 日本: zoho.jp
# - US:  zoho.com
# - EU:  zoho.eu
# - IN:  zoho.in
ZOHO_REGION=zoho.jp

# OAuth Self-Client から発行された Client ID / Secret
ZOHO_CLIENT_ID=
ZOHO_CLIENT_SECRET=

# Self-Client の Grant Code を curl で交換して得た refresh_token（永続）
ZOHO_REFRESH_TOKEN=

# Zoho Analytics のワークスペース ID（URL の /workspace/<ID>/ 部分）
ZOHO_WORKSPACE_ID=

# Organization ID（Settings > Account Info か、`python main.py workspaces` で取得）
ZOHO_ORG_ID=
